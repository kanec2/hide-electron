{
  "name": "hxelectron-demo",
  "version": "0.3.0",
  "license": "MIT",
  "description": "A minimal Electron application",
  "repository": "https://github.com/tong/hxelectron",
  "main": "main.js",
  "window":{
    "title": "Custom Hide",
    "url": "app.html",
    "width": 1000, 
    "height": 700,
    "frame": true, 
    "icon": "icon-192.png"
  },
  "scripts": {
    "clean": "rm -f main.js* app.js*",
    "build-main": "haxe main.hxml",
    "build-app": "haxe app.hxml",
    "build": "npm run build-main && npm run build-app",
    "start": "electron . --no-sandbox --enable-logging --unbuffered"
  },
  "devDependencies": {
    "electron": "v40.1.0",
    "@electron/rebuild": "^3.7.0"
  }
}
