{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Build & Start",
      "preLaunchTask": "build-then-start",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/app.js",
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}